PHONE_NUMBER_ID=          # Phone Number ID מ-Meta Business
VERIFY_TOKEN=tori_verify_secret_2024   # אל תשנה אלא אם תשנה גם ב-Meta

# ==============================
# Google Gemini AI
# ==============================
GEMINI_API_KEY=           # מ-Google AI Studio / Vertex
GEMINI_MODEL=gemini-2.5-flash   # אופציונלי — דריסת מודל (ברירת מחדל: gemini-2.5-flash)

# ==============================
# Supabase
# ==============================
